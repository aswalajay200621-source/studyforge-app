// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  notes         Note[]
  flashcards    Flashcard[]
  quizzes       Quiz[]
  studyRooms    StudyRoomMember[]
  
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Note {
  id          String   @id @default(cuid())
  title       String
  subject     String
  content     String   @db.Text
  htmlContent String?  @db.Text
  fileName    String?
  fileSize    Int?
  wordCount   Int      @default(0)
  color       String   @default("#8B5CF6")
  isPinned    Boolean  @default(false)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([subject])
  @@map("notes")
}

model Flashcard {
  id        String   @id @default(cuid())
  title     String
  subject   String
  cards     Json     // Array of {front, back, mastered}
  color     String   @default("#10B981")
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([subject])
  @@map("flashcards")
}

model Quiz {
  id          String   @id @default(cuid())
  title       String
  subject     String
  questions   Json     // Array of {question, options, correctAnswer, explanation}
  totalScore  Int      @default(0)
  userScore   Int?
  completed   Boolean  @default(false)
  color       String   @default("#F59E0B")
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([subject])
  @@map("quizzes")
}

model StudyRoom {
  id            String            @id @default(cuid())
  name          String
  subject       String
  code          String            @unique
  maxParticipants Int            @default(4)
  isPrivate     Boolean           @default(false)
  isActive      Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  
  members       StudyRoomMember[]
  messages      StudyRoomMessage[]

  @@index([code])
  @@index([subject])
  @@map("study_rooms")
}

model StudyRoomMember {
  id          String     @id @default(cuid())
  userId      String
  roomId      String
  role        String     @default("member") // "host" or "member"
  isOnline    Boolean    @default(true)
  joinedAt    DateTime   @default(now())
  
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  room        StudyRoom  @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([userId, roomId])
  @@index([roomId])
  @@map("study_room_members")
}

model StudyRoomMessage {
  id        String     @id @default(cuid())
  roomId    String
  userId    String
  userName  String
  message   String     @db.Text
  createdAt DateTime   @default(now())
  
  room      StudyRoom  @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId])
  @@map("study_room_messages")
}